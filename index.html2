<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MNA 湄公产业资本联盟 · 财税业务管理平台</title>

<!-- ================== SheetJS ================== -->
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

<style>
  /* ================== 原有全部 CSS 样式（一字未改） ================== */
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'WenQuanYi Micro Hei', 'Noto Sans CJK SC', sans-serif;
    background: #f0f2f5; color: #333; font-size: 14px; min-height: 100vh;
  }

  /* ========== 登录页面 ========== */
  .login-page {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #0f2b5e 0%, #1a4a8a 40%, #1e6fb3 100%);
    position: relative; overflow: hidden;
  }
  .login-page::before { content:''; position:absolute; width:500px; height:500px; background:rgba(255,255,255,0.04); border-radius:50%; top:-150px; left:-150px; }
  .login-page::after { content:''; position:absolute; width:400px; height:400px; background:rgba(255,255,255,0.03); border-radius:50%; bottom:-120px; right:-120px; }
  .login-box {
    background: #fff; border-radius: 16px; padding: 44px 40px; width: 440px; max-width: 92vw;
    box-shadow: 0 16px 50px rgba(0,0,0,0.2); position: relative; z-index: 1;
  }
  .login-logo { text-align: center; margin-bottom: 6px; }
  .login-logo .icon { font-size: 52px; }
  .login-logo h2 { font-size: 22px; color: #0f2b5e; margin: 8px 0 4px; }
  .login-logo p { font-size: 12px; color: #888; line-height: 1.6; }
  .login-form { margin-top: 28px; }
  .login-form .form-group { margin-bottom: 18px; }
  .login-form label { display: block; font-weight: 500; color: #555; margin-bottom: 6px; font-size: 13px; }
  .login-form input, .login-form select {
    width: 100%; padding: 10px 14px; border: 1px solid #d9d9d9; border-radius: 8px;
    font-size: 14px; font-family: inherit; transition: border-color 0.2s;
  }
  .login-form input:focus, .login-form select:focus { border-color: #1a4a8a; outline: none; box-shadow: 0 0 0 2px rgba(26,74,138,0.12); }
  .login-btn {
    width: 100%; padding: 12px; background: linear-gradient(135deg, #0f2b5e, #1a4a8a);
    color: #fff; border: none; border-radius: 8px; font-size: 15px; font-weight: 600;
    cursor: pointer; transition: opacity 0.2s; font-family: inherit;
  }
  .login-btn:hover { opacity: 0.9; }
  .login-error { color: #ff4d4f; font-size: 13px; text-align: center; margin-top: 12px; min-height: 20px; }
  .login-footer { text-align: center; margin-top: 24px; font-size: 11px; color: #bbb; }
  .login-links { display: flex; justify-content: space-between; margin-top: 14px; font-size: 12px; }
  .login-links a { color: #1a4a8a; cursor: pointer; text-decoration: none; }
  .login-links a:hover { text-decoration: underline; }

  /* ========== 主应用布局 ========== */
  .app-container { display: none; min-height: 100vh; }
  .app-header {
    background: linear-gradient(135deg, #0f2b5e 0%, #1a4a8a 100%);
    color: #fff; padding: 0 32px; height: 64px;
    display: flex; justify-content: space-between; align-items: center;
    position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }
  .app-header .brand { display: flex; align-items: center; gap: 12px; }
  .app-header .brand .logo-icon { font-size: 28px; }
  .app-header .brand .brand-text h1 { font-size: 18px; font-weight: 700; letter-spacing: 1px; }
  .app-header .brand .brand-text p { font-size: 10px; opacity: 0.7; margin-top: 1px; }
  .app-header .user-bar { display: flex; align-items: center; gap: 14px; font-size: 13px; }
  .app-header .user-bar .avatar { width: 34px; height: 34px; border-radius: 50%; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 16px; }
  .app-header .user-bar .user-info { text-align: right; }
  .app-header .user-bar .user-info .uname { font-weight: 600; }
  .app-header .user-bar .user-info .urole { font-size: 11px; opacity: 0.6; }
  .app-header .user-bar button { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.25); color: #fff; padding: 5px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; font-family: inherit; transition: background 0.2s; }
  .app-header .user-bar button:hover { background: rgba(255,255,255,0.22); }

  /* ========== 主内容区 ========== */
  .main-body { display: flex; min-height: calc(100vh - 64px); }
  .sidebar {
    width: 240px; background: #fff; border-right: 1px solid #e8e8e8; padding: 16px 0;
    flex-shrink: 0; overflow-y: auto;
  }
  .sidebar .nav-group { margin-bottom: 8px; }
  .sidebar .nav-group-title {
    padding: 6px 20px; font-size: 11px; color: #aaa; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;
  }
  .sidebar .nav-item {
    display: flex; align-items: center; gap: 10px; padding: 10px 20px; cursor: pointer;
    color: #555; font-size: 13.5px; font-weight: 500; transition: all 0.2s;
    border-left: 3px solid transparent; background: none; border-top: none; border-right: none; border-bottom: none; width: 100%; text-align: left; font-family: inherit;
  }
  .sidebar .nav-item .nav-icon { font-size: 18px; width: 24px; text-align: center; }
  .sidebar .nav-item:hover { background: #f6f9ff; color: #1a4a8a; }
  .sidebar .nav-item.active { background: #eef3ff; color: #1a4a8a; border-left-color: #1a4a8a; font-weight: 600; }
  .content-area { flex: 1; padding: 24px; overflow-y: auto; }

  /* ========== 通用组件 ========== */
  .page-section { display: none; animation: fadeIn 0.2s ease; }
  .page-section.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .panel { background: #fff; border-radius: 12px; padding: 24px; box-shadow: 0 1px 6px rgba(0,0,0,0.06); margin-bottom: 20px; }
  .panel h3 { font-size: 16px; color: #0f2b5e; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
  .panel h3 .sub { font-size: 12px; color: #999; font-weight: 400; }
  .controls { display: flex; gap: 12px; align-items: center; margin-bottom: 20px; flex-wrap: wrap; }
  .controls label { font-weight: 500; color: #555; white-space: nowrap; font-size: 13px; }
  .controls select, .controls input, .controls button {
    padding: 7px 14px; border: 1px solid #d9d9d9; border-radius: 6px; font-size: 13px; font-family: inherit;
  }
  .controls select, .controls input { background: #fff; }
  .controls button { background: #1a4a8a; color: #fff; border: none; cursor: pointer; transition: background 0.2s; font-weight: 500; }
  .controls button:hover { background: #0f2b5e; }
  .btn-green { background: #52c41a !important; } .btn-green:hover { background: #389e0d !important; }
  .btn-red { background: #ff4d4f !important; } .btn-red:hover { background: #cf1322 !important; }
  .btn-orange { background: #fa8c16 !important; } .btn-orange:hover { background: #d46b08 !important; }
  .btn-gray { background: #f5f5f5 !important; color: #666 !important; } .btn-gray:hover { background: #e8e8e8 !important; }
  .btn-teal { background: #13c2c2 !important; } .btn-teal:hover { background: #08979c !important; }
  .btn-purple { background: #722ed1 !important; } .btn-purple:hover { background: #531dab !important; }
  .btn-gold { background: #d48806 !important; } .btn-gold:hover { background: #b37f00 !important; }
.btn-old { background: #7cb305 !important; } .btn-old:hover { background: #5b8c00 !important; }

  /* 汇总卡片 */
  .summary-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }
  .card { background: #fff; border-radius: 12px; padding: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.06); text-align: center; border-top: 3px solid #1a4a8a; }
  .card .label { font-size: 12px; color: #888; margin-bottom: 8px; }
  .card .value { font-size: 28px; font-weight: 700; color: #0f2b5e; }
  .card .value.profit { color: #52c41a; } .card .value.rebate { color: #fa8c16; } .card .value.cost { color: #ff4d4f; }
  .card .unit { font-size: 11px; color: #aaa; margin-top: 4px; }

  /* 表格 */
  .table-wrapper { background: #fff; border-radius: 12px; box-shadow: 0 1px 6px rgba(0,0,0,0.06); overflow: hidden; }
  .table-header { padding: 16px 20px; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
  .table-header h3 { font-size: 15px; color: #0f2b5e; }
  table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  thead th { background: #fafbfc; padding: 11px 8px; text-align: center; font-weight: 600; color: #555; border-bottom: 1px solid #e8e8e8; font-size: 12px; }
  tbody td { padding: 10px 6px; text-align: center; border-bottom: 1px solid #f5f5f5; }
  tbody tr:hover { background: #f6f9ff; } tbody tr { cursor: pointer; }
  .total-row td { background: #f0f5ff; font-weight: 700; color: #0f2b5e; font-size: 13px; }
  .actions button { padding: 3px 10px; font-size: 11.5px; border: none; border-radius: 4px; cursor: pointer; margin: 0 1px; font-family: inherit; }
  .actions .edit-btn { background: #e6f7ff; color: #1a4a8a; } .actions .del-btn { background: #fff1f0; color: #ff4d4f; }
  .actions .view-btn { background: #f6ffed; color: #52c41a; }

  /* 状态标签 */
  .status-badge { display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: 11px; font-weight: 600; white-space: nowrap; }
  .st-0 { background: #e6f7ff; color: #1a4a8a; } .st-1 { background: #fff7e6; color: #d46b08; }
  .st-2 { background: #f6ffed; color: #389e0d; } .st-3 { background: #f9e6ff; color: #722ed1; }
  .st-4 { background: #e6fffb; color: #08979c; } .st-5 { background: #fff1e6; color: #fa8c16; }
  .st-6 { background: #f6ffed; color: #52c41a; } .st-7 { background: #f0f5ff; color: #0f2b5e; }
  .st-active { background: #e6f7ff; color: #1a4a8a; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(26,74,138,0.25); } 50% { box-shadow: 0 0 0 6px rgba(26,74,138,0); } }

  /* 弹窗 */
  .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.45); z-index: 1000; justify-content: center; align-items: center; }
  .modal-overlay.active { display: flex; }
  .modal { background: #fff; border-radius: 14px; padding: 28px; width: 600px; max-width: 95vw; max-height: 90vh; overflow-y: auto; box-shadow: 0 12px 40px rgba(0,0,0,0.18); }
  .modal h3 { margin-bottom: 20px; color: #0f2b5e; font-size: 18px; }
  .form-row { display: flex; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; }
  .form-group { margin-bottom: 12px; flex: 1; min-width: 180px; }
  .form-group label { display: block; margin-bottom: 5px; font-weight: 500; color: #555; font-size: 12.5px; }
  .form-group input, .form-group select, .form-group textarea {
    width: 100%; padding: 8px 12px; border: 1px solid #d9d9d9; border-radius: 6px; font-size: 13.5px; font-family: inherit;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: #1a4a8a; outline: none; }
  .form-group textarea { resize: vertical; min-height: 60px; }
  .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }
  .modal-actions button { padding: 8px 22px; border-radius: 6px; font-size: 14px; cursor: pointer; font-family: inherit; border: none; font-weight: 500; }
  .modal-actions .btn-cancel { background: #f5f5f5; color: #666; } .modal-actions .btn-cancel:hover { background: #e8e8e8; }
  .modal-actions .btn-submit { background: #1a4a8a; color: #fff; } .modal-actions .btn-submit:hover { background: #0f2b5e; }

  /* 时间线 */
  .timeline { position: relative; padding-left: 28px; margin-top: 12px; }
  .timeline::before { content:''; position:absolute; left:10px; top:0; bottom:0; width:2px; background:#e8e8e8; }
  .timeline-item { position: relative; margin-bottom: 16px; }
  .timeline-item::before { content:''; position:absolute; left:-22px; top:3px; width:12px; height:12px; border-radius:50%; border:2px solid #d9d9d9; background:#fff; z-index:1; }
  .timeline-item.done::before { background: #52c41a; border-color: #52c41a; }
  .timeline-item.active::before { background: #1a4a8a; border-color: #1a4a8a; animation: pulse 1.5s infinite; }
  .timeline-item .tl-title { font-weight: 600; font-size: 13px; color: #333; }
  .timeline-item .tl-time { font-size: 12px; color: #999; margin-top: 2px; }
  .timeline-item .tl-detail { font-size: 12px; color: #666; margin-top: 2px; }

  /* 空状态 */
  .empty-state { text-align: center; padding: 48px 20px; color: #bbb; }
  .empty-state .icon { font-size: 48px; margin-bottom: 12px; }
  .empty-state p { font-size: 14px; }

  /* Toast */
  .toast { position: fixed; top: 20px; right: 20px; padding: 12px 24px; border-radius: 8px; color: #fff; font-size: 14px; z-index: 2000; display: none; animation: slideIn 0.3s ease; }
  .toast.show { display: block; } .toast.success { background: #52c41a; } .toast.error { background: #ff4d4f; }
  @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

  .footer-note { text-align: center; padding: 20px; color: #bbb; font-size: 12px; }

  /* 仪表盘 */
  .dashboard-welcome { background: linear-gradient(135deg, #0f2b5e, #1a4a8a); color: #fff; border-radius: 12px; padding: 28px; margin-bottom: 24px; }
  .dashboard-welcome h2 { font-size: 22px; margin-bottom: 6px; } .dashboard-welcome p { font-size: 13px; opacity: 0.8; }
  .dashboard-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; margin-bottom: 24px; }
  .dashboard-card { background: #fff; border-radius: 12px; padding: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.06); border-left: 4px solid #1a4a8a; }
  .dashboard-card h4 { font-size: 14px; color: #333; margin-bottom: 8px; } .dashboard-card p { font-size: 12px; color: #888; line-height: 1.8; }
  .dashboard-card .big-num { font-size: 32px; font-weight: 700; color: #1a4a8a; }

  /* 详情面板 */
  .detail-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid #f0f0f0; }
  .detail-header h3 { font-size: 18px; color: #0f2b5e; }
  .detail-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin-bottom: 16px; }
  .detail-item { background: #fafafa; padding: 10px 14px; border-radius: 8px; }
  .detail-item .di-label { font-size: 11px; color: #999; margin-bottom: 4px; } .detail-item .di-value { font-size: 14px; font-weight: 600; color: #333; }

  /* 筛选栏 */
  .filter-bar { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 16px; }
  .filter-bar select, .filter-bar input { padding: 6px 12px; border: 1px solid #d9d9d9; border-radius: 6px; font-size: 13px; font-family: inherit; }

  /* 配置 */
  .config-row { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  .config-row label { font-weight: 500; color: #555; white-space: nowrap; font-size: 13px; }
  .config-row input { width: 120px; padding: 6px 10px; border: 1px solid #d9d9d9; border-radius: 6px; font-size: 14px; font-family: inherit; }

  .role-badge { display: inline-block; padding: 1px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; }
  .role-badge.admin { background: #fff7e6; color: #d46b08; } .role-badge.user { background: #e6f7ff; color: #1a4a8a; }
  .user-list-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; border: 1px solid #f0f0f0; border-radius: 8px; margin-bottom: 8px; background: #fafafa; }
  .user-list-item .u-info { text-align: left; } .user-list-item .u-name { font-weight: 600; color: #333; } .user-list-item .u-role { font-size: 12px; color: #999; }
  .user-list-item .u-actions { display: flex; gap: 6px; } .user-list-item .u-actions button { padding: 3px 10px; font-size: 12px; border-radius: 4px; border: none; cursor: pointer; font-family: inherit; }

  .order-no { font-family: 'Courier New', monospace; font-weight: 700; color: #0f2b5e; font-size: 12px; }

  /* 进度条 */
  .progress-bar-wrap { width: 100%; height: 8px; background: #f0f0f0; border-radius: 4px; overflow: hidden; margin-bottom: 2px; }
  .progress-bar-fill { height: 100%; background: linear-gradient(90deg, #1a4a8a, #52c41a); border-radius: 4px; transition: width 0.3s; }

  /* Tab 子导航 */
  .sub-tabs { display: flex; gap: 0; margin-bottom: 20px; border-bottom: 1px solid #e8e8e8; }
  .sub-tabs button { padding: 10px 20px; cursor: pointer; font-weight: 500; color: #888; border: none; border-bottom: 2px solid transparent; background: none; font-size: 13.5px; font-family: inherit; transition: all 0.2s; }
  .sub-tabs button.active { color: #1a4a8a; border-bottom-color: #1a4a8a; } .sub-tabs button:hover { color: #1a4a8a; }

  .section-title { font-size: 15px; color: #0f2b5e; font-weight: 600; margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
  .tag { display: inline-block; padding: 1px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; background: #f0f0f0; color: #666; }
  .tag-blue { background: #e6f7ff; color: #1a4a8a; } .tag-green { background: #f6ffed; color: #52c41a; } .tag-orange { background: #fff7e6; color: #d46b08; }
  .tag-purple { background: #f9e6ff; color: #722ed1; } .tag-teal { background: #e6fffb; color: #08979c; } .tag-red { background: #fff1f0; color: #ff4d4f; }
  .tag-gold { background: #fff7e6; color: #d48806; }
  /* 支出相关 */
  .expense-row td { color: #ff4d4f; }
  .income-row td { color: #52c41a; }
  .finance-summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-bottom: 20px; }
  .finance-card { background: #fff; border-radius: 10px; padding: 16px; text-align: center; box-shadow: 0 1px 4px rgba(0,0,0,0.06); border-top: 3px solid #1a4a8a; }
  .finance-card .flabel { font-size: 11px; color: #999; margin-bottom: 6px; }
  .finance-card .fvalue { font-size: 22px; font-weight: 700; }
  .finance-card .fvalue.positive { color: #52c41a; }
  .finance-card .fvalue.negative { color: #ff4d4f; }
  .finance-card .fvalue.neutral { color: #0f2b5e; }
  .finance-card .fsub { font-size: 11px; color: #bbb; margin-top: 4px; }
  .expense-cat { display: inline-block; padding: 1px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; }
  .ecat-rent { background: #fff1f0; color: #ff4d4f; }
  .ecat-salary { background: #fff7e6; color: #d48806; }
  .ecat-utility { background: #e6f7ff; color: #1a4a8a; }
  .ecat-travel { background: #f6ffed; color: #52c41a; }
  .ecat-marketing { background: #f9e6ff; color: #722ed1; }
  .ecat-office { background: #e6fffb; color: #08979c; }
  .ecat-other { background: #f0f0f0; color: #666; }
  /* 职业技能培训 */
  .tag-teal { background: #e6fffb; color: #13c2c2; }
  .tag-purple { background: #f9e6ff; color: #722ed1; }
  .tag-gold { background: #fff7e6; color: #d48806; }

  /* ================== 中英文切换按钮样式 ================== */
  .lang-switch {
    cursor: pointer;
    padding: 4px 10px;
    border-radius: 6px;
    background: rgba(255,255,255,0.15);
    color: #fff;
    font-size: 12px;
    border: 1px solid rgba(255,255,255,0.3);
    user-select: none;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .lang-switch:hover {
    background: rgba(255,255,255,0.25);
  }
</style>
</head>
<body>

<!-- ==================== 登录页面 ==================== -->
<div class="login-page" id="loginPage">
  <div class="login-box">
    <div class="login-logo">
      <div class="icon">🏛️</div>
      <h2 data-i18n="login_title">MNA 业务管理平台</h2>
      <p data-i18n="login_sub">湄公产业资本联盟 Mekong Nexus Association连接产业 · 资本 · 政府 · 国际资源
      <p data-i18n="login_footer">© 2025 MNA · 仅授权用户可访问 · 数据加密存储
    </div>
    <div class="login-form">
      <div class="form-group">
        <label data-i18n="login_username">👤 用户名</label>
        <input type="text" id="loginUser" placeholder="请输入用户名" autocomplete="username" autofocus>
      </div>
      <div class="form-group">
        <label data-i18n="login_password">🔑 密码</label>
        <input type="password" id="loginPass" placeholder="请输入密码" autocomplete="current-password">
      </div>
      <button class="login-btn" onclick="doLogin()" data-i18n="login_btn">登 录</button>
      <div class="login-error" id="loginError"></div>
    </div>
    <div class="login-links">
      <a onclick="showResetPassword()" data-i18n="forgot_pwd">忘记密码？</a>
      <span id="registerLink" style="display:none">
        <a onclick="showRegister()" data-i18n="register">注册新用户</a>
      </span>
    </div>
    <div class="login-footer" data-i18n="login_copyright">© 2025 MNA · 仅授权用户可访问 · 数据加密存储</div>
  </div>
</div>

<!-- ==================== 注册页面 ==================== -->
<div class="login-page" id="registerPage" style="display:none">
  <div class="login-box">
    <div class="login-logo">
      <div class="icon">📝</div>
      <h2 data-i18n="register_title">注册新账户</h2>
      <p data-i18n="register_sub">创建您的 MNA 系统账户
    </div>
    <div class="login-form">
      <div class="form-group">
        <label data-i18n="login_username">👤 用户名</label>
        <input type="text" id="regUser" placeholder="请输入用户名（3-20位）">
      </div>
      <div class="form-group">
        <label data-i18n="login_password">🔑 密码</label>
        <input type="password" id="regPass" placeholder="请输入密码（至少6位）">
      </div>
      <div class="form-group">
        <label data-i18n="confirm_pwd">🔑 确认密码</label>
        <input type="password" id="regPass2" placeholder="请再次输入密码">
      </div>
      <div class="form-group">
        <label data-i18n="role">🎭 角色</label>
        <select id="regRole" style="width:100%;padding:10px 14px;border:1px solid #d9d9d9;border-radius:8px;font-size:14px;font-family:inherit">
          <option value="user" data-i18n="role_user">普通用户</option>
          <option value="admin" data-i18n="role_admin">管理员</option>
        </select>
      </div>
      <button class="login-btn" onclick="doRegister()" data-i18n="register_btn">注 册</button>
      <div class="login-error" id="regError"></div>
    </div>
    <div class="login-links">
      <a onclick="backToLogin()" data-i18n="back_login">← 返回登录</a>
    </div>
  </div>
</div>

